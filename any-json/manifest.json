{
  "manifest_version": 3,
  "name": "Any JSON Quick Copy",
  "version": "1.0",
  "description": "Import any JSON and rapidly paste values into web forms",
  "permissions": [
    "storage",
    "sidePanel",
    "activeTab"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Any JSON Quick Copy"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
