{
  "manifest_version": 3,
  "name": "Band Info Quick Copy",
  "version": "1.0",
  "description": "Quickly copy band information for online forms",
  "key": "",
  "permissions": [
    "storage",
    "sidePanel"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Band Info Quick Copy"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}